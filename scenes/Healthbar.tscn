[sub_resource type="GDScript" id="GDScript_e2b52"]
script/source = "extends ProgressBar
@onready var damagebar = $Damagebar
@onready var timer = $Timer

func _ready():
	timer.timeout.connect(_on_timer_timeout)

func init_health(max_health: float):
	max_value = max_health
	value = max_health
	
	damagebar.max_value = max_health
	damagebar.value = max_health

func set_health(new_health: float):
	value = new_health
	
	timer.start()

func _on_timer_timeout():
	var tween = create_tween()
	
	tween.set_trans(Tween.TRANS_SINE)
	tween.set_ease(Tween.EASE_OUT)
	
	# Tween the damagebar's \"value\" property to match the current healthbar \"value\"
	# The last number (0.4) is how long the animation takes in seconds
	tween.tween_property(damagebar, \"value\", value, 0.4)
"

